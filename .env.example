# Copy this file to .env and fill in your key(s).
# app.py and start.sh will load .env automatically:
#   cp .env.example .env

# ── AI Provider ──────────────────────────────────────────────────────────────
# Set ACTIVE_PROVIDER to control which AI backend is used.
# Values: anthropic | openai | ollama
# If unset, falls back to whichever key is present (anthropic takes priority).
ACTIVE_PROVIDER=anthropic

# Anthropic — get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-key-here
# Anthropic model (claude-sonnet-4-6 | claude-opus-4-7 | claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=
# OpenAI model to use (gpt-5.5 | gpt-5.4 | gpt-5.4-mini | gpt-4.1 | gpt-4o | gpt-4o-mini)
OPENAI_MODEL=gpt-4o

# Ollama — local models, no API key required (https://ollama.com)
# Note: web-search sections (Company Research, Interview Intel, Salary Coach) are not available with Ollama
OLLAMA_BASE_URL=http://localhost:11434
# Model name must match a model you have pulled: ollama pull llama3.2
OLLAMA_MODEL=llama3.2

# Langfuse observability (optional)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASEURL=http://localhost:3000
